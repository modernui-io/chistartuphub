# ===========================================
# ChiStartup Hub Environment Variables
# ===========================================
#
# SETUP INSTRUCTIONS:
#
# FOR LOCAL DEVELOPMENT:
#   1. Run `npm run db:start` to start local Supabase
#   2. Run `npx supabase status` to get local credentials
#   3. Copy .env.local.example to .env.local
#   4. Update .env.local with values from supabase status
#   5. Run `npm run dev` - it will use .env.local automatically
#
# FOR PRODUCTION:
#   1. Copy this file to .env
#   2. Fill in production values from Supabase dashboard
#
# ===========================================

# --- Supabase Configuration ---
# Get these from https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# For MCP Server (get from https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=your-personal-access-token
SUPABASE_PROJECT_REF=your-project-ref

# --- Vercel Configuration ---
# Get from https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token

# --- Google Analytics ---
# Get from https://analytics.google.com → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Resend (for email notifications) ---
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- PostHog Analytics ---
# Get from https://us.posthog.com → Project Settings → Project API Key
VITE_PUBLIC_POSTHOG_KEY=phc_your-project-key
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
